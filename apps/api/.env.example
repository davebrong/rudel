# Postgres connection string (DATABASE_URL or PG_CONNECTION_STRING)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/rudel

# better-auth secret (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=

# Google OAuth (optional — only needed for Google sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (optional — only needed for GitHub sign-in)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
